{
	// Use IntelliSense to learn about possible attributes.
	// Hover to view descriptions of existing attributes.
	// For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
	"version": "0.2.0",
	"configurations": [
		{
			"type": "firefox",
			"request": "launch",
			"reAttach": true,
			"name": "Firefox: Launch localhost",
			"url": "http://localhost:3000",
			"webRoot": "${workspaceFolder}",
			"reloadOnAttach": true,
			"pathMappings": [
				{
					"url": "webpack://_N_E",
					"path": "${workspaceFolder}"
				},
				{
					"url": "webpack:///",
					"path": "${workspaceFolder}"
				},
				{
					"url": "webpack://",
					"path": "${workspaceFolder}"
				}
			]
		},
		{
			"name": "Next dev (npm run dev)",
			"type": "node-terminal",
			"request": "launch",
			"command": "export NVM_DIR=\"$HOME/.nvm\"; [ -s \"$NVM_DIR/nvm.sh\" ] && . \"$NVM_DIR/nvm.sh\"; nvm use; npm run dev"
		},
		{
			"name": "Next dev (webpack for Firefox debug)",
			"type": "node-terminal",
			"request": "launch",
			"command": "export NVM_DIR=\"$HOME/.nvm\"; [ -s \"$NVM_DIR/nvm.sh\" ] && . \"$NVM_DIR/nvm.sh\"; nvm use; npm run dev -- --webpack"
		}
	]
}